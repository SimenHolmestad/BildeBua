{
  "name": "bildebua-frontend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.26.1",
    "swr": "^2.4.1",
    "web-vitals": "^3.5.2"
  },
  "devDependencies": {
    "@playwright/test": "^1.53.0",
    "@hey-api/openapi-ts": "^0.73.0",
    "@types/react": "^18.3.5",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.27",
    "postcss": "^8.5.8",
    "tailwindcss": "^3.4.17",
    "vite": "^5.4.6"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview --host",
    "gen:api": "openapi-ts -f openapi-ts.config.ts",
    "test:e2e": "playwright test -c playwright.config.js",
    "test:e2e:headed": "playwright test -c playwright.config.js --headed",
    "test:e2e:ui": "playwright test -c playwright.config.js --ui",
    "test:e2e:screenshots": "playwright test -c playwright.screenshot.config.js",
    "test:e2e:update-snapshots": "playwright test -c playwright.screenshot.config.js --update-snapshots"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  }
}
